{
  "name": "@tychilabs/ugf-testnet-js",
  "version": "0.1.3",
  "description": "UGF testnet SDK — gasless transactions on Base Sepolia. No ETH required. Pay gas in TYI mock USD.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ethers": "^6.13.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "ugf",
    "universal-gas-framework",
    "remote-transaction",
    "gasless",
    "gas-sponsorship",
    "testnet",
    "base-sepolia",
    "tyi-mock-usd",
    "x402",
    "x402-protocol",
    "evm",
    "web3",
    "agentic",
    "ai-agents",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TychiWallet/ugf-testnet-js.git"
  },
  "homepage": "https://universalgasframework.com",
  "bugs": {
    "url": "https://github.com/TychiWallet/ugf-testnet-js/issues"
  },
  "license": "Apache-2.0"
}
